+static NSString *CornerfixInstallRelativeDylibPath(void) {
+    char rawPath[PATH_MAX];
+    uint32_t bufSize = sizeof(rawPath);
+    if (_NSGetExecutablePath(rawPath, &bufSize) != 0) {
+        return nil;
+    }
+    NSString *raw = [NSString stringWithUTF8String:rawPath];
+    NSString *resolved = [[NSURL fileURLWithPath:raw] URLByResolvingSymlinksInPath].path;
+    if (resolved.length == 0) {
+        return nil;
+    }
+    NSString *exeDir = [resolved stringByDeletingLastPathComponent];
+    return [[exeDir stringByAppendingPathComponent:@"../lib/cornerfix/libcornerfix.dylib"] stringByStandardizingPath];
+}
