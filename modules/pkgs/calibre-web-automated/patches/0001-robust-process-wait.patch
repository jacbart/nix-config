+def _clean_subprocess_env():
+    # Strip PYTHONPATH/PYTHONHOME so child binaries (e.g. Calibre's bundled
+    # Python under Nix) don't inherit CWA's Flask/etc. site-packages.
+    env = dict(os.environ)
+    env.pop('PYTHONPATH', None)
+    env.pop('PYTHONHOME', None)
+    return env
+
